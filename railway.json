{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd apps/backend && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "variables": {
    "REDIS_URL": "${{ Redis.REDIS_PRIVATE_URL }}",
    "CORS_ORIGIN": "https://kurerghor.vercel.app",
    "NODE_ENV": "production",
    "FRONTEND_URL": "https://kurerghor.vercel.app"
  }
}
