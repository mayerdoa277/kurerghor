{
  "version": 2,
  "builds": [
    {
      "src": "apps/backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "apps/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/backend/src/app.js"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "apps/backend/src/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "apps/frontend/dist/$1"
    }
  ],
  "functions": {
    "apps/backend/src/app.js": {
      "maxDuration": 30
    }
  },
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace=apps/frontend"
}
