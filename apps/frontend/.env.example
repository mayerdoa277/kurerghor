# API Configuration
# Development
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000

# Production (Vercel Frontend + Railway Backend)
# Uncomment these for production
# VITE_API_URL=https://your-railway-app-name.up.railway.app/api/v1
# VITE_SOCKET_URL=https://your-railway-app-name.up.railway.app

# Alternative Production URLs
# For custom domain backend:
# VITE_API_URL=https://api.yourdomain.com/api/v1
# VITE_SOCKET_URL=https://api.yourdomain.com

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# CDN Configuration
VITE_CDN_URL=https://your-bunny-cdn-url.b-cdn.net

# App Configuration
VITE_APP_NAME=Ecommerce Platform
VITE_APP_VERSION=1.0.0
